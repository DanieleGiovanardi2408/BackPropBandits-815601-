# === LLM backend (ReportAgent) ===
# LLM_BACKEND: 'anthropic' (DEFAULT, cloud Claude) | 'openai_compatible'
#   (local LM Studio / Ollama / vLLM) | 'none' (deterministic templates, no LLM).
LLM_BACKEND=anthropic

# --- Cloud Claude (used when LLM_BACKEND=anthropic) ---
# Add your real API key in .env (never commit real keys)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- Local self-hosted (used when LLM_BACKEND=openai_compatible) ---
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=qwen2.5-3b-instruct
LLM_API_KEY=lm-studio

# === Report narration / cost-efficiency ===
# LLM_NARRATE_LEVELS: final_risk tiers narrated by the LLM (rest get a template).
#   CRITICAL,HIGH = operational severity (recommended, bounded cost on large
#   perimeters); CRITICAL,HIGH,MEDIUM = every anomalous route; CRITICAL = leanest.
LLM_NARRATE_LEVELS=CRITICAL,HIGH
# LLM_CONCURRENCY: parallel LLM requests for cache-miss routes. Keep 1 on a
# memory-bandwidth-bound CPU (concurrency caused contention there); raise on GPU.
LLM_CONCURRENCY=1
# LLM_DEDUP_THRESHOLD: above this many LLM-narrated routes, narrate one example
# per risk pattern + templates for the rest (bounds cost on large perimeters);
# at/below it every narrated route gets its own LLM explanation. 0 = always dedup.
LLM_DEDUP_THRESHOLD=15

# === Runtime flags ===
# USE_LLM: enable LLM calls when run_report=True
USE_LLM=false
# DRY_RUN: if true, skip LLM calls and generate placeholder explanations
DRY_RUN=true
